'use strict';

const router = require('express').Router();
const pool   = require('../db');
const { requireAuth } = require('../middleware/auth');

function dd(v) {
  if (!v) return '';
  const d = new Date(v);
  if (isNaN(d)) return v;
  const z = n => String(n).padStart(2,'0');
  return `${z(d.getDate())}/${z(d.getMonth()+1)}/${d.getFullYear()}`;
}

async function getExportRows(query) {
  const { status, client, carrier, from, to, field = 'inbound' } = query;
  const where  = ['o.is_archived=0','o.is_deleted=0'];
  const params = [];

  if (status && status !== 'all') { where.push('o.status=?'); params.push(status); }
  if (client)  { where.push('o.client_id=?');    params.push(client); }
  if (carrier) { where.push('o.carrier=?');      params.push(carrier); }

  const dateCol = { inbound:'o.inbound_dt', scheduled:'o.scheduled_ship_date', outbound:'o.outbound_dt' }[field] || 'o.inbound_dt';
  if (from) { where.push(`${dateCol} >= ?`); params.push(from); }
  if (to)   { where.push(`${dateCol} <= ?`); params.push(to + ' 23:59:59'); }

  const [rows] = await pool.execute(
    `SELECT o.order_no, o.shipment_no, o.client_id, o.customer_name, o.dest_country,
            o.carrier, o.service_level, o.tracking_no, o.scheduled_ship_date,
            o.inbound_dt, o.outbound_dt, o.status, o.internal_ref, o.shipping_notes,
            p.pallet_id, p.pkg_type, p.location_type, p.staging_loc, p.notes AS pallet_notes
     FROM orders o
     LEFT JOIN pallets p ON p.order_no = o.order_no
     WHERE ${where.join(' AND ')}
     ORDER BY o.order_no, p.seq_no`,
    params
  );
  return rows;
}

const CSV_HEADERS = [
  'Client ID','Customer Name','Destination Country','Order Number','Shipment No.',
  'Pallet ID / LPN','Package Type','Location Type','Staging Location','Carrier',
  'Service Level','Tracking Number','Scheduled Ship Date','Inbound Date',
  'Outbound Date','Status','Internal Reference','Shipping Notes',
];

function rowToCSV(r) {
  return [
    r.client_id, r.customer_name||'', r.dest_country||'', r.order_no, r.shipment_no,
    r.pallet_id||'', r.pkg_type||'', r.location_type||'', r.staging_loc||'',
    r.carrier||'', r.service_level||'', r.tracking_no||'',
    dd(r.scheduled_ship_date), dd(r.inbound_dt), dd(r.outbound_dt),
    r.status||'', r.internal_ref||'', r.shipping_notes||'',
  ].map(v => `"${String(v||'').replace(/"/g,'""')}"`).join(',');
}

// GET /api/export/csv
router.get('/csv', requireAuth, async (req, res) => {
  try {
    const rows = await getExportRows(req.query);
    const ts   = new Date().toISOString().slice(0,10);
    res.setHeader('Content-Type', 'text/csv; charset=utf-8');
    res.setHeader('Content-Disposition', `attachment; filename="KN_TrackFlow_Export_${ts}.csv"`);
    res.send([CSV_HEADERS.join(','), ...rows.map(rowToCSV)].join('\n'));
  } catch (err) {
    res.status(500).json({ error: err.message });
  }
});

// GET /api/export/excel
router.get('/excel', requireAuth, async (req, res) => {
  try {
    const XLSX = require('xlsx');
    const rows = await getExportRows(req.query);
    const ts   = new Date().toISOString().slice(0,10);

    const data = rows.map(r => [
      r.client_id, r.customer_name||'', r.dest_country||'',
      r.order_no, r.shipment_no, r.pallet_id||'', r.pkg_type||'',
      r.location_type||'', r.staging_loc||'', r.carrier||'',
      r.service_level||'', r.tracking_no||'',
      dd(r.scheduled_ship_date), dd(r.inbound_dt), dd(r.outbound_dt),
      r.status||'', r.internal_ref||'', r.shipping_notes||'',
    ]);

    const wb = XLSX.utils.book_new();
    const ws = XLSX.utils.aoa_to_sheet([CSV_HEADERS, ...data]);
    ws['!cols'] = CSV_HEADERS.map(() => ({ wch: 18 }));
    XLSX.utils.book_append_sheet(wb, ws, 'Orders');

    // Summary sheet
    const uniqueOrders = new Set(rows.map(r => r.order_no));
    const summary = [
      ['KN Track Flow — Export'],
      ['Generated', new Date().toLocaleString()],
      ['Total Orders', uniqueOrders.size],
      ['Total Pallet Rows', rows.length],
    ];
    XLSX.utils.book_append_sheet(wb, XLSX.utils.aoa_to_sheet(summary), 'Summary');

    const buf = XLSX.write(wb, { type: 'buffer', bookType: 'xlsx' });
    res.setHeader('Content-Type', 'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet');
    res.setHeader('Content-Disposition', `attachment; filename="KN_TrackFlow_Export_${ts}.xlsx"`);
    res.send(buf);
  } catch (err) {
    res.status(500).json({ error: err.message });
  }
});

module.exports = router;
